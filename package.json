{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev -o",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "simple-git-hooks",
    "up": "taze latest -I -f",
    "prettier": "prettier --write .",
    "lint": "eslint .",
    "nuxt": "nuxt"
  },
  "dependencies": {
    "@unocss/reset": "^66.6.7",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@ayingott/eslint-config": "^2.1.3",
    "@ayingott/prettier-config": "^2.1.11",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/qlementine-icons": "^1.2.14",
    "@nuxtjs/color-mode": "^4.0.0",
    "@unocss/eslint-plugin": "66.6.7",
    "@unocss/nuxt": "^66.6.7",
    "@vue/language-core": "^3.2.6",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.10.0",
    "typescript": "^6.0.2",
    "unocss": "^66.6.7",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "prettier": "@ayingott/prettier-config"
}
